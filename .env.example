# ── Upstox ──────────────────────────────────────
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:8000/upstox/callback

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://iway:changeme@postgres:5432/investorsway
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Trading config ───────────────────────────────
CAPITAL=200000          # total capital in Rs.
RISK_PCT=1.0            # risk per trade as % of capital
ATR_LEN=14              # ATR period
SL_LOOKBACK=5           # bars for swing low SL

# ── App ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
OHLCV_LOOKBACK_DAYS=400
